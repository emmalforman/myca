# Supabase (required for persistent storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Notion - Form Database (applications + CRM)
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=1cbf6a28bb29803c9815c333d33ad2e9

# Notion - Directory Database (optional, if separate from form)
NOTION_DIRECTORY_DATABASE_ID=206f6a28bb298103b5d5f4aad517c562

# Admin access — comma-separated list of admin email addresses
# These users can access applications, sync data, manage events, etc.
# Also receives notifications when new applications are submitted.
ADMIN_EMAILS=emma@mycacollective.com

# Resend — for transactional emails (new application notifications)
# Get an API key at https://resend.com
RESEND_API_KEY=re_your_key_here
